{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mychannel.app/schema/streamers.json",
  "title": "Streamers provider manifest",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "shortName",
      "logo",
      "regions",
      "tmdbProviderIds",
      "tmdbProviderNames",
      "searchUrlTemplates"
    ],
    "properties": {
      "id": {
        "type": "string",
        "enum": [
          "netflix",
          "prime",
          "disney",
          "appletv",
          "max",
          "hulu",
          "peacock",
          "paramount",
          "showtime",
          "starz",
          "youtube"
        ]
      },
      "name": { "type": "string", "minLength": 1 },
      "shortName": { "type": "string", "minLength": 1 },
      "logo": { "type": "string", "pattern": "^assets/streamers/[a-z0-9]+\\.png$" },
      "regions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "type": "string", "enum": ["ZA", "US"] }
      },
      "tmdbProviderIds": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        }
      },
      "tmdbProviderNames": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "searchUrlTemplates": {
        "type": "object",
        "additionalProperties": false,
        "required": ["web", "ios", "android"],
        "properties": {
          "web": { "type": "string", "pattern": "^https://.*\\{query\\}" },
          "ios": { "type": "string", "minLength": 1 },
          "android": { "type": "string", "minLength": 1 }
        }
      },
      "notes": { "type": "string" }
    }
  }
}

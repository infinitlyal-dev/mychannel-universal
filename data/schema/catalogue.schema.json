{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mychannel.app/schema/catalogue.json",
  "title": "Catalogue (array of Show)",
  "type": "array",
  "items": { "$ref": "#/$defs/Show" },
  "$defs": {
    "Region": { "type": "string", "enum": ["ZA", "US"] },
    "StreamerId": {
      "type": "string",
      "enum": ["netflix", "disney", "prime", "max", "appletv", "hulu", "paramount", "peacock", "youtube"]
    },
    "GenreId": {
      "type": "string",
      "enum": ["drama", "comedy", "crime", "scifi", "fantasy", "thriller", "action", "romance", "documentary", "animation", "horror", "reality"]
    },
    "DeepLinkSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "android": { "type": "string", "format": "uri" },
        "ios": { "type": "string", "minLength": 1 },
        "web": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "Show": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "tmdbId", "tmdbType", "title", "year",
        "posterUrl", "backdropUrl", "genres", "runtimeMinutes",
        "providers", "deepLinks"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^tmdb-(tv|movie)-[0-9]+$" },
        "tmdbId": { "type": "integer", "minimum": 1 },
        "tmdbType": { "type": "string", "enum": ["tv", "movie"] },
        "title": { "type": "string", "minLength": 1 },
        "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "posterUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
        "backdropUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
        "genres": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/GenreId" }
        },
        "runtimeMinutes": { "type": "integer", "minimum": 1, "maximum": 600 },
        "providers": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "ZA": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/StreamerId" }
            },
            "US": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/StreamerId" }
            }
          }
        },
        "deepLinks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "netflix": { "$ref": "#/$defs/DeepLinkSet" },
            "disney": { "$ref": "#/$defs/DeepLinkSet" },
            "prime": { "$ref": "#/$defs/DeepLinkSet" },
            "max": { "$ref": "#/$defs/DeepLinkSet" },
            "appletv": { "$ref": "#/$defs/DeepLinkSet" },
            "hulu": { "$ref": "#/$defs/DeepLinkSet" },
            "paramount": { "$ref": "#/$defs/DeepLinkSet" },
            "peacock": { "$ref": "#/$defs/DeepLinkSet" },
            "youtube": { "$ref": "#/$defs/DeepLinkSet" }
          }
        }
      }
    }
  }
}

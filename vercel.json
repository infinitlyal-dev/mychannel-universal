{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd app && npm install && npm run build:bundle",
  "outputDirectory": "app/www",
  "framework": null,
  "cleanUrls": true,
  "installCommand": "npm install --prefix app",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mychannel-api.vercel.app/api/:path*"
    }
  ]
}

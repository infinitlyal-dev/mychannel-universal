{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:bundle",
  "outputDirectory": "www",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mychannel-api.vercel.app/api/:path*"
    }
  ]
}

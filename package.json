{
  "name": "mychannel-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Universal My-Channel — TV + phone, multi-region cross-streamer personal channel. Separate product from v5 Netflix demo. Shares DNA (Al voice, Rachel intro, TMDB, state schema) but built fresh from Editorial Cinema register.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "esbuild www/lib/*.js --bundle=false --outdir=www/lib --allow-overwrite",
    "serve": "python -m http.server 5173 --directory www"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "esbuild": "^0.21.5",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/app-launcher": "^6.0.4",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3"
  }
}
